{
  "manifest_version": 3,
  "name": "TabPet",
  "description": "A tiny browser pet that idles, wanders, and keeps you company while you browse.",
  "version": "0.1.0",
  "action": {
    "default_title": "TabPet",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
